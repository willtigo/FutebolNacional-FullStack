@page "/jogos"
@using FutebolNacional.Models
@using System.Net.Http.Json
@inject IHttpClientFactory ClientFactory

<style>
    /* Sobrescreve o hover do Bootstrap para um cinza mais visível */
    .table-hover tbody tr:hover {
        background-color: #d1d1d1 !important; /* Um cinza médio mais escuro */
        transition: background-color 0.2s ease-in-out; /* Suaviza a transição */
        cursor: pointer; /* Indica que a linha é interativa */
    }

        /* Opcional: Deixa o texto levemente mais nítido no hover */
        .table-hover tbody tr:hover td {
            color: #000;
            font-weight: 500;
        }

    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Garante que todos os elementos internos ocupem 100% da altura do container de 45px */
    .flex-nowrap > .btn, .flex-nowrap > .input-group {
        height: 100%;
    }

    /* Força os ícones a ficarem brancos dentro dos botões escuros */
    .btn-dark i {
        color: #ffffff !important;
        font-size: 1.1rem;
    }

    /* Deixa os botões desativados com uma transparência para indicar que não funcionam */
    .btn-dark:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    /* Remove contornos azuis chatos ao clicar */
    .btn:focus, .form-control:focus {
        box-shadow: none !important;
        outline: none !important;
    }

    /* Efeito de animação para o Skeleton */
    .skeleton {
        background: #e0e0e0;
        background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
        background-size: 200% 100%;
        animation: skeleton-loading 1.5s infinite;
        border-radius: 4px;
        height: 20px;
        width: 100%;
        display: inline-block;
    }

    @@keyframes skeleton-loading {
        0% {
            background-position: 200% 0;
        }

        100% {
            background-position: -200% 0;
        }
    }

    .escudo-filtro {
        width: 45px;
        height: 45px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin: 5px;
        filter: grayscale(100%); /* Fica P&B por padrão */
        opacity: 0.6;
    }

        .escudo-filtro:hover {
            transform: scale(1.2);
            filter: grayscale(0%);
            opacity: 1;
        }

    .escudo-ativo {
        filter: grayscale(0%) !important;
        opacity: 1 !important;
        border: 3px solid #005c2d; /* Verde do Brasileirão */
        border-radius: 50%;
        padding: 2px;
        box-shadow: 0 0 10px rgba(0,92,45,0.5);
    }

    .mascote-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1000;
        pointer-events: none; /* Permite clicar no que estiver atrás do mascote */
        animation: slideInRight 0.8s ease-out; /* Efeito de entrada */
    }

    .mascote-img {
        height: 250px; /* Ajuste o tamanho conforme preferir */
        width: auto;
        opacity: 0.8; /* Leve transparência para ser discreto */
        filter: drop-shadow(5px 5px 15px rgba(0,0,0,0.3));
        transition: opacity 0.3s;
    }

    /* Animação para o mascote "entrar" na tela ao selecionar o time */
    @@keyframes slideInRight {
        from {
            transform: translateX(100px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 0.8;
        }
    }

    .modal-banner {
        height: 200px;
        background-size: cover;
        background-position: center;
        border-radius: 8px 8px 0 0;
        position: relative;
    }

    .modal-banner-overlay {
        position: absolute;
        bottom: 0;
        width: 100%;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        color: white;
        padding: 10px 20px;
    }

    /* Timeline de Eventos */
    .evento-item {
        padding: 8px;
        border-bottom: 1px solid #eee;
        display: flex;
        align-items: center;
    }

    .minuto-badge {
        width: 45px;
        font-weight: bold;
        color: #666;
    }

    .fa-futbol {
        color: #28a745;
    }
    /* Gol Verde */
    .fa-id-card.text-warning {
        color: #ffc107;
    }
    /* Amarelo */
    .fa-id-card.text-danger {
        color: #dc3545;
    }
    /* Vermelho */
    .fa-exchange-alt {
        color: #007bff;
    }
    /* Subs Azul */
    .fa-video {
        color: #6f42c1;
    }
    /* VAR Roxo */

    .placar-modal {
        background: #fff;
        margin-top: -30px; /* Faz o placar "subir" sobre o banner */
        border-radius: 15px;
        position: relative;
        z-index: 10;
    }

    .timeline-container {
        position: relative;
        padding: 20px 0;
    }

        /* Linha central da timeline */
        .timeline-container::before {
            content: '';
            position: absolute;
            left: 50%;
            width: 2px;
            height: 100%;
            background: #dee2e6;
        }

    .evento-row {
        display: flex;
        width: 100%;
        margin-bottom: 15px;
        position: relative;
    }

    /* Evento do Mandante (Esquerda) */
    .evento-mandante {
        justify-content: flex-start;
        padding-right: 52%;
        text-align: right;
    }

    /* Evento do Visitante (Direita) */
    .evento-visitante {
        justify-content: flex-end;
        padding-left: 52%;
        text-align: left;
    }

    .minuto-central {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        background: #fff;
        border: 2px solid #dee2e6;
        border-radius: 50%;
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: bold;
        z-index: 5;
    }
</style>


<div class="d-flex align-items-center justify-content-center bg-light p-4 mb-4 rounded shadow-sm"
     style="border-left: 8px solid #005c2d; border-right: 8px solid #f9dd16;">

    <img src="img/escudos/brasileiro.png" alt="Logo Brasileirão"
         style="height: 80px; margin-right: 20px;" />

    <div class="text-center">
        <h2 class="fw-bold mb-0" style="color: #004a29; letter-spacing: 1px;">
            CAMPEONATO BRASILEIRO
        </h2>
        <span class="badge bg-dark text-white text-uppercase" style="font-size: 0.9rem; letter-spacing: 2px;">
            Temporadas 2022 • 2023 • 2024
        </span>
    </div>
</div>

<div class="card shadow-sm mb-4 border-0">
    <div class="card-body bg-light rounded">
        <!-- Removi o d-flex daqui -->
        <div class="row align-items-center">
            <!-- 1. Filtro de Ano -->
            <div class="col-md-3">
                <label class="me-2 mb-0 fw-bold text-dark">Temporada:</label>
                <select class="form-select form-select-sm d-inline-block" @onchange="FiltrarPorAno" style="width: 100px;">
                    <option value="2024">2024</option>
                    <option value="2023">2023</option>
                    <option value="2022">2022</option>
                </select>
            </div>

            <!-- 2. Navegação Central (Onde estão os ícones) -->
            <div class="col-md-6 d-flex justify-content-center">
                <div class="d-flex flex-nowrap align-items-stretch shadow-lg bg-dark rounded p-1" style="height: 46px; border: 1px solid #444;">
                    <button class="btn btn-dark border-0 px-3" @onclick="() => NavegarRodada(1)" disabled="@(rodadaAtual == 1)">
                        <i class="fa-solid fa-angles-left text-white"></i>
                    </button>
                    <button class="btn btn-dark border-0 px-3 border-end border-secondary" @onclick="() => NavegarRodada(rodadaAtual - 1)" disabled="@(rodadaAtual == 1)">
                        <i class="fa-solid fa-angle-left text-white"></i>
                    </button>

                    <div class="input-group input-group-sm mx-1" style="width: auto; min-width: 120px;">
                        <span class="input-group-text bg-light border-0 fw-bold d-none d-sm-flex" style="font-size: 0.65rem; color: #333;">RODADA</span>
                        <input type="number" class="form-control text-center fw-bold border-0"
                               style="width: 55px !important; font-size: 1.2rem;"
                               @bind="rodadaInput" @onkeypress="HandleKeyPress" />
                        <button class="btn btn-success fw-bold border-0 px-3" @onclick="IrParaRodadaDigitada">OK</button>
                    </div>

                    <button class="btn btn-dark border-0 px-3 border-start border-secondary" @onclick="() => NavegarRodada(rodadaAtual + 1)" disabled="@(rodadaAtual == totalRodadas)">
                        <i class="fa-solid fa-angle-right text-white"></i>
                    </button>
                    <button class="btn btn-dark border-0 px-3" @onclick="() => NavegarRodada(totalRodadas)" disabled="@(rodadaAtual == totalRodadas)">
                        <i class="fa-solid fa-angles-right text-white"></i>
                    </button>
                </div>
            </div>

            <!-- 3. Contador -->
            <div class="col-md-3 text-end d-none d-md-block">
                <span class="badge bg-secondary p-2">Total: @(jogos?.Count ?? 0)</span>
            </div>

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-body bg-light rounded text-center">
                    <h6 class="text-muted fw-bold mb-3" style="font-size: 0.75rem; letter-spacing: 1px;">FILTRAR POR CLUBE</h6>

                    <div class="d-flex flex-wrap justify-content-center align-items-center">
                        <!-- Botão para Limpar Filtro (Ver todos) -->
                        <button class="btn btn-sm btn-outline-secondary rounded-circle me-3"
                                @onclick="() => SelecionarTime(null)" title="Ver todos os jogos">
                            <i class="fas fa-undo"></i>
                        </button>

                        @if (listaClubes != null)
                        {
                            @foreach (var time in listaClubes)
                            {
                                <img src="img/escudos/@(time).png"
                                     title="@time"
                                     class="escudo-filtro @(timeSelecionado == time ? "escudo-ativo" : "")"
                                     @onclick="() => SelecionarTime(time)"
                                     onerror="this.src='img/escudos/default.png';" />
                            }
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(timeSelecionado))
                    {
                        <div class="mt-2 text-success fw-bold">Exibindo jogos de: @timeSelecionado</div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@if (jogosExibidos == null)
{
    <table class="table mt-3">
        <thead>
            <tr class="thead-dark">
                <th>Data</th>
                <th>Mandante</th>
                <th>Placar</th>
                <th>Visitante</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < 10; i++)
            {
                <tr>
                    <td><div class="skeleton" style="width: 80px;"></div></td>
                    <td><div class="skeleton"></div></td>
                    <td class="text-center"><div class="skeleton" style="width: 50px;"></div></td>
                    <td><div class="skeleton"></div></td>
                </tr>
            }
        </tbody>
    </table> }
else if (!jogosExibidos.Any())
{
    <div class="alert alert-warning text-center">
        Nenhum jogo encontrado para a <strong>Rodada @rodadaAtual</strong> em <strong>@anoSelecionado</strong>.
    </div> }
else
{
    <table class="table table-striped table-hover mt-3" style="table-layout: fixed; width: 100%;">
        <thead style="background-color: @corDestaque; color: white; transition: background-color 0.5s;">
            <tr>
                <th style="width: 20%;">Data</th>
                <th class="text-right" style="width: 30%;">Mandante</th>
                <th class="text-center" style="width: 20%;">Placar</th>
                <th class="text-left" style="width: 30%;">Visitante</th>
            </tr>
        </thead>
        <tbody>
            @if (jogosExibidos != null)
            {
                @foreach (var jogo in jogosExibidos)
                {
                    <tr @onclick="() => AbrirModal(jogo)" style="cursor: pointer;">
                        <td style="vertical-align: middle; overflow: hidden; white-space: nowrap;">
                            <b>@jogo.DataJogo.ToShortDateString()</b>
                        </td>

                        @* Coluna do Mandante - Estabilizada com Sigla *@
                        <td class="text-right" style="vertical-align: middle;">
                            <span class="fw-bold" title="@jogo.TimeMandante"><b>@GerarSigla(jogo.TimeMandante)</b></span>
                            <img src="img/escudos/@(jogo.TimeMandante).png"
                                 width="30" height="30"
                                 style="margin-left: 10px;"
                                 onerror="this.src='img/escudos/default.png';" />
                        </td>

                        @* Coluna do Placar *@
                        <td class="text-center" style="vertical-align: middle;">
                            <span class="badge rounded-pill @GetPlacarColor(jogo.GolsMandante, jogo.GolsVisitante)"
                                  style="font-size: 1.1rem; padding: 8px 15px; min-width: 80px;">
                                @jogo.GolsMandante x @jogo.GolsVisitante
                            </span>
                        </td>

                        @* Coluna do Visitante - Estabilizada com Sigla *@
                        <td class="text-left" style="vertical-align: middle;">
                            <img src="img/escudos/@(jogo.TimeVisitante).png"
                                 width="30" height="30"
                                 style="margin-right: 10px;"
                                 onerror="this.src='img/escudos/default.png';" />
                            <span class="fw-bold" title="@jogo.TimeVisitante"><b>@GerarSigla(jogo.TimeVisitante)</b></span>
                        </td>
                    </tr>
                }}
        </tbody>
    </table>

    @if (!string.IsNullOrEmpty(timeSelecionado))
    {
        <div class="mascote-container d-none d-md-block">
            <img src="img/mascotes/@(timeSelecionado).png"
                 alt="Mascote @timeSelecionado"
                 class="mascote-img"
                 onerror="this.style.display='none';" />
        </div>
    }

    @if (exibirModal && jogoSelecionado != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 bg-transparent">

                    <!-- 1. Banner Superior -->
                    <div class="modal-banner" style="background-image: url('img/estadios/@(jogoSelecionado.Estadio).jpg'), url('img/estadios/default.jpg'); border-radius: 15px 15px 0 0;">
                        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" @onclick="FecharModal"></button>
                        <div class="modal-banner-overlay text-center pb-5">
                            <small class="text-uppercase fw-bold" style="letter-spacing: 2px;">
                                <i class="fas fa-map-marker-alt"></i> @jogoSelecionado.Estadio
                            </small>
                        </div>
                    </div>

                    <!-- 2. Bloco do Placar (Centralizado) -->
                    <div class="container py-3 shadow placar-modal mx-auto w-75 text-center">
                        <div class="row align-items-center">
                            <div class="col-4 text-end">
                                <span class="fw-bold d-block d-sm-inline">@jogoSelecionado.TimeMandante</span>
                                <img src="img/escudos/@(jogoSelecionado.TimeMandante).png" width="45" class="ms-2" />
                            </div>
                            <div class="col-4">
                                <h2 class="fw-bold mb-0">@jogoSelecionado.GolsMandante x @jogoSelecionado.GolsVisitante</h2>
                            </div>
                            <div class="col-4 text-start">
                                <img src="img/escudos/@(jogoSelecionado.TimeVisitante).png" width="45" class="me-2" />
                                <span class="fw-bold d-block d-sm-inline">@jogoSelecionado.TimeVisitante</span>
                            </div>
                        </div>
                    </div>

                    <!-- 3. Timeline de Eventos -->
                    <div class="modal-body bg-white rounded-bottom p-4" style="max-height: 400px; overflow-y: auto;">
                        @if (eventosPartida != null)
                        {
                            <div class="timeline-container">
                                @foreach (var ev in eventosPartida)
                                {
                                    bool isMandante = ev.TimeNome == jogoSelecionado.TimeMandante;
                                    <div class="evento-row @(isMandante ? "evento-mandante" : "evento-visitante")">

                                        <div class="minuto-central">@ev.Minuto'</div>

                                        <div class="evento-content">
                                            @if (ev.Tipo == "Goal")
                                            {<i class="fas fa-futbol mx-1 text-success"></i> }
                                            else if (ev.Tipo == "Card")
                                            { <i class="fas fa-id-card mx-1 @(ev.Detalhe.Contains("Yellow") ? "text-warning" : "text-danger")"></i>}

                                            <strong>@ev.Jogador</strong>
                                            <div class="text-muted small">@ev.Detalhe</div>
                                        </div>
                                    </div>}
                            </div>}
                    </div>
                </div>
            </div>
        </div>}


}

}


@code { // Mantemos suas variáveis originais
    private List<Jogo> jogos; // Lista completa do ano (vinda da API)
    private List<Jogo> jogosExibidos; // Lista filtrada da rodada atual (exibida no HTML)
    private string anoSelecionado = "2024"; // Iniciando com 2024
    private int rodadaAtual = 1;
    private const int totalRodadas = 38;
    private int rodadaInput = 1; // Variável para o campo de texto
    private List<string> listaClubes; // Armazena os times únicos do ano
    private string timeSelecionado = ""; // Armazena o time que o usuário clicou
    private string corDestaque = "#212529"; // Cinza padrão
    private bool exibirModal = false;
    private Jogo jogoSelecionado;
    private List<EventosJogos> eventosPartida;

    // Dicionário simples com as cores principais dos clubes
    private Dictionary<string, string> coresClubes = new()
    {
            { "Atletico Paranaense", "#D50024" },
            { "Atletico Goianiense", "#000000" },
            { "Atletico-MG", "#231F20" },
            { "Bahia", "#0067B2" },
            { "Botafogo", "#000000" },
            { "RB Bragantino", "#E11A27" },
            { "Corinthians", "#131313" },
            { "Criciuma", "#F8D116" }, // Dica: Aqui o texto pode precisar ser preto
            { "Coritiba", "#006437" },
            { "Cruzeiro", "#003399" },
            { "Cuiaba", "#006225" },
            { "Flamengo", "#C40000" },
            { "Fluminense", "#820E2D" },
            { "Fortaleza EC", "#103E91" },
            { "Gremio", "#0D80BF" },
            { "Internacional", "#E20E0E" },
            { "Juventude", "#008144" },
            { "Palmeiras", "#006437" },
            { "Santos", "#1D1D1B" },
            { "Sao Paulo", "#FE0000" },
            { "Vasco DA Gama", "#000000" },
            { "Vitoria", "#BE151B" }
            // Adicione os demais conforme necessário
        };


    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        try
        {
            var client = ClientFactory.CreateClient("BrasileiraoAPI");
            jogos = await client.GetFromJsonAsync<List<Jogo>>($"api/jogos?ano={anoSelecionado}");

            if (jogos != null)
            {
                // Extrai todos os times únicos (Mandantes e Visitantes) e ordena de A-Z
                listaClubes = jogos.Select(j => j.TimeMandante)
                                   .Union(jogos.Select(j => j.TimeVisitante))
                                   .OrderBy(t => t)
                                   .ToList();

                AtualizarPagina();
            }
        }
        catch (Exception ex) { /* log erro */ }
    }

    private void SelecionarTime(string time)
    {
        timeSelecionado = time;
        // Se o time estiver no dicionário, pega a cor dele, senão volta para o padrão
        if (!string.IsNullOrEmpty(time) && coresClubes.ContainsKey(time))
        {
            corDestaque = coresClubes[time];
        }
        else
        {
            corDestaque = "#212529"; // Reset para o padrão
        }
        AtualizarPagina();
    }

    // NOVA LÓGICA: Filtra a lista 'jogos' para gerar a 'jogosExibidos'
    private void AtualizarPagina()
    {
        // 1. Ativa o efeito de esqueleto (Skeleton Screen) antes de processar
        jogosExibidos = null;
        StateHasChanged();

        if (jogos == null) return;

        // 2. Lógica de Filtro: Prioriza o Time Selecionado, senão filtra por Rodada
        if (!string.IsNullOrEmpty(timeSelecionado))
        {
            // Busca todos os jogos onde o time selecionado participou (Mandante ou Visitante)
            jogosExibidos = jogos
                .Where(j => j.TimeMandante == timeSelecionado || j.TimeVisitante == timeSelecionado)
                .OrderBy(j => j.DataJogo)
                .ToList();
        }
        else
        {
            // Caso não haja time selecionado, volta para o filtro padrão de Rodada
            // "Regular Season - X"
            string termoBusca = $"Regular Season - {rodadaAtual}";

            // Importante: usei 'j.rodada' conforme o seu método original
            jogosExibidos = jogos.Where(j => j.rodada == termoBusca).ToList();
        }

        // 3. Avisa ao Blazor que os dados estão prontos para substituir o esqueleto
        StateHasChanged();
    }

    // Adaptado: Agora reseta a rodada ao mudar o ano
    private async Task FiltrarPorAno(ChangeEventArgs e)
    {
        anoSelecionado = e.Value?.ToString();
        rodadaAtual = 1; // Reinicia na rodada 1 ao trocar o ano
        await CarregarDados();
    }

    // NOVO: Método para os botões de navegação
    private void NavegarRodada(int novaRodada)
    {
        if (novaRodada >= 1 && novaRodada <= totalRodadas)
        {
            rodadaAtual = novaRodada;
            rodadaInput = novaRodada; // Mantém o input sincronizado com as setas
            AtualizarPagina();
        }
    }

    // Método para o botão de "Ir" (ícone de refresh)
    private void IrParaRodadaDigitada()
    {
        if (rodadaInput >= 1 && rodadaInput <= totalRodadas)
        {
            rodadaAtual = rodadaInput;
            AtualizarPagina();
        }
        else
        {
            // Opcional: Resetar para o valor anterior se digitar algo inválido
            rodadaInput = rodadaAtual;
        }
    }

    // Atalho: Se o usuário apertar "Enter" dentro do campo, ele também navega
    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            IrParaRodadaDigitada();
        }
    }

    // Mantendo sua lógica de cores intacta
    private string GetPlacarColor(int golsMandante, int golsVisitante)
    {
        if (golsMandante > golsVisitante)
            return "bg-success";

        if (golsMandante < golsVisitante)
            return "bg-danger";

        return "bg-secondary";
    }

    private string GerarSigla(string nomeTime)
    {
        if (string.IsNullOrEmpty(nomeTime)) return "---";

        // Pega as 3 primeiras letras e coloca em maiúsculo
        // Ex: "Palmeiras" -> "PAL"
        return nomeTime.Substring(0, Math.Min(3, nomeTime.Length)).ToUpper();
    }

    private async Task AbrirModal(Jogo jogo)
    {
        jogoSelecionado = jogo;
        exibirModal = true;
        eventosPartida = null; // Mostra o spinner

        try
        {
            var client = ClientFactory.CreateClient("BrasileiraoAPI");
            // Ajuste a URL para o endpoint que criamos na sua API
            eventosPartida = await client.GetFromJsonAsync<List<EventosJogos>>($"api/jogos/eventos/{jogo.Id}");
        }
        catch
        {
            eventosPartida = new List<EventosJogos>();
        }
    }

    private void FecharModal()
    {
        exibirModal = false;
        jogoSelecionado = null;
    }

}
